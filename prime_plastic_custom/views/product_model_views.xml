<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_product_model_list" model="ir.ui.view">
            <field name="name">product.model.list</field>
            <field name="model">product.model</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_product_model_form" model="ir.ui.view">
            <field name="name">product.model.form</field>
            <field name="model">product.model</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="name"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_product_model" model="ir.actions.act_window">
            <field name="name">Model</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.model</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Model...!
                </p>
            </field>
        </record>

        <menuitem id="menu_action_product_model"
                  name="Model"
                  parent="stock.menu_product_in_config_stock"
                  action="action_product_model"
                  sequence="3"/>

    </data>
</odoo>
