<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_material_material_list" model="ir.ui.view">
            <field name="name">material.material.list</field>
            <field name="model">material.material</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_material_material_form" model="ir.ui.view">
            <field name="name">material.material.form</field>
            <field name="model">material.material</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="name"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_material_material" model="ir.actions.act_window">
            <field name="name">Material</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">material.material</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Material...!
                </p>
            </field>
        </record>

        <menuitem id="menu_action_material_material"
                  name="Material"
                  parent="stock.menu_product_in_config_stock"
                  action="action_material_material"
                  sequence="4"/>

    </data>
</odoo>
