<odoo>
    <data>


        <record id="product_template_only_form_view_inherit" model="ir.ui.view">
            <field name="name">product.template.only.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook/page[last()]" position="after">
                    <page name="product_info" string="Product Info">
                        <group>
                            <group>
                                <field name="product_color_id" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}"/>
                                <field name="product_model_id" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}" />
                                <field name="product_material_id" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}" />
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>