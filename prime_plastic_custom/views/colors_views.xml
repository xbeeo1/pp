<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_color_color_list" model="ir.ui.view">
            <field name="name">color.color.list</field>
            <field name="model">color.color</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_color_color_form" model="ir.ui.view">
            <field name="name">color.color.form</field>
            <field name="model">color.color</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                        <group>
                            <field name="name"/>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_color_color" model="ir.actions.act_window">
            <field name="name">Colors</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">color.color</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Your First Color...!
                </p>
            </field>
        </record>

        <menuitem id="menu_action_color_color"
                  name="Color"
                  parent="stock.menu_product_in_config_stock"
                  action="action_color_color"
                  sequence="2"/>

    </data>
</odoo>
