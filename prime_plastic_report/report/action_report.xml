<odoo>

    <record id="custom_paperformat" model="report.paperformat">
            <field name="name">Custom</field>
            <field name="default" eval="True" />
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">50</field>
            <field name="margin_bottom">20</field>
            <field name="margin_left">0</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">50</field>
            <field name="dpi">90</field>
        </record>

    <record id="action_product_stock_report" model="ir.actions.report">
        <field name="name">Product Stock Report</field>
        <field name="model">product.stock.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">prime_plastic_report.product_stock_report_template</field>
        <field name="report_file">prime_plastic_report.product_stock_report_template</field>
        <field name="paperformat_id" ref="prime_plastic_report.custom_paperformat"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">"Product Stock Report"</field>
    </record>
</odoo>