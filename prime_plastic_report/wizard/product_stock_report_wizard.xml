<?xml version="1.0" encoding="utf-8" ?>

<odoo>
    <data>

        <record id="product_stock_report_wizard_view" model="ir.ui.view">
            <field name="name">product.stock.report.wizard</field>
            <field name="model">product.stock.report</field>
            <field name="arch" type="xml">
                <form string="Product Report Wizard">
<!--                    <sheet>-->
                    <group>
                        <group>
                            <field name="product_ids" widget="many2many_tags" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}"/>
                        </group>
                        <group>
                            <field name="warehouse_id" options="{'no_quick_create': True, 'no_create_edit': True,'no_open': True, 'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <button string="Print Report" name="print_report" type="object"
                                class="oe_highlight" data-hotkey="q"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                    </group>

<!--                    </sheet>-->
                    <footer>
                    </footer>
                </form>
            </field>
        </record>

        <record id="product_stock_report_window_act" model="ir.actions.act_window">
            <field name="name">Product Stock Report</field>
            <field name="res_model">product.stock.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="product_stock_report_wizard_view"/>
        </record>

        <menuitem id="menu_product_stock_report"
                  name="Product Component Stock Report"
                  parent="stock.menu_warehouse_report"
                  action="product_stock_report_window_act"
                  sequence="10"/>

    </data>
</odoo>